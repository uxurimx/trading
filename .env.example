# ──────────────────────────────────────────────────────────────────
# QTS — Quantum Trading System · Configuración
# Crea tus API keys en: https://www.bybit.com/app/user/api-management
# Permisos requeridos: Read (mercado + cuenta), Trade (para órdenes)
# ──────────────────────────────────────────────────────────────────

# Bybit API
BYBIT_API_KEY=tu_api_key_aqui
BYBIT_API_SECRET=tu_api_secret_aqui
BYBIT_TESTNET=false

# Símbolos a monitorear (separados por coma)
SYMBOLS=XRPUSDT,SOLUSDT,BTCUSDT,ETHUSDT,XLMUSDT
DEFAULT_SYMBOL=XRPUSDT

# Base de datos
DB_PATH=storage/trading.duckdb

# Risk Management (Fase 5)
MAX_DAILY_LOSS_PCT=2.0
MAX_TRADES_PER_DAY=10
